    <!--
        Dynamic course pages: generate these programmatically.
        Either:
        1. Use a build-time script that queries Supabase and writes this file, OR
        2. Use a sitemap route handler if you add SSR/edge functions.

        Example format for each course:
        <url>
            <loc>https://zverts.vercel.app/courses/[slug]</loc>
            <lastmod>YYYY-MM-DD</lastmod>
